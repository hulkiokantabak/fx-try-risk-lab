FX_APP_NAME=FX TRY Risk Lab
FX_ENVIRONMENT=production
FX_HOST=0.0.0.0
FX_PORT=8000
FX_RELOAD=false
FX_FORWARDED_ALLOW_IPS=127.0.0.1
FX_SECURE_COOKIES=true
FX_DATABASE_URL=sqlite:///data/app.db
FX_DATA_DIR=/app/data
FX_REPORTS_DIR=/app/data/reports
FX_EXPORTS_DIR=/app/data/exports
FX_EVIDENCE_DIR=/app/data/evidence_packs
FX_RAW_DATA_DIR=/app/data/raw
FX_NORMALIZED_DATA_DIR=/app/data/normalized
FX_LOG_DIR=/app/data/logs
FX_ALLOWED_HOSTS=your-domain.example.com,127.0.0.1,localhost
FX_SESSION_SECRET=replace-with-a-long-random-secret
FX_SOURCE_FETCH_TIMEOUT_SECONDS=15
FX_SOURCE_FETCH_MAX_BYTES=2000000
